{% extends 'base.html.twig' %}

{% block title %}Ajouter un Pokémon
{% endblock %}

{% block body %}

	<div class="row justify-conteont-center">

		<div class="col-12 col-md-6 col-lg-4">
			<div class="card-shadow-sm">

				<div class="card-header bg-danger text-white">
					<h3>Ajouter un pokémon</h3>
				</div>
				<div class="card_body">
					<form>
						<div class="mb-3">
							<label for="name" class="form-label">Nom du Pokémon</label>
							<input type="text" class="form-control" placeholder="Mystherbe" name="name">
						</div>
						<div class="mb-3">
							<label for="name" class="form-label">Numéro Pokédex national</label>
							<input type="number" class="form-control" placeholder="483" name="number">
						</div>
						<div class="mb-3">
							<button type="submit" class="btn btn-danger">Ajouter</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
